{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "linkedin": { "type": "string" },
        "github": { "type": "string" },
        "summary": { "type": "string" },
        "skills": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    }
  }
}
